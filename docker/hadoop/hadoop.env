HADOOP_HOME=/opt/hadoop
HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop

# Match mini-Hadoop config for fair comparison
# Block size: 128MB
# Replication: 3
# Heartbeat interval: 3s

CORE-SITE.XML_fs.defaultFS=hdfs://hadoop-namenode:8020
CORE-SITE.XML_hadoop.tmp.dir=/opt/hadoop-data/tmp

HDFS-SITE.XML_dfs.replication=3
HDFS-SITE.XML_dfs.blocksize=134217728
HDFS-SITE.XML_dfs.namenode.name.dir=/opt/hadoop-data/namenode
HDFS-SITE.XML_dfs.datanode.data.dir=/opt/hadoop-data/datanode
HDFS-SITE.XML_dfs.namenode.heartbeat.recheck-interval=5000
HDFS-SITE.XML_dfs.heartbeat.interval=3

YARN-SITE.XML_yarn.resourcemanager.hostname=hadoop-resourcemanager
YARN-SITE.XML_yarn.nodemanager.resource.memory-mb=4096
YARN-SITE.XML_yarn.nodemanager.resource.cpu-vcores=4
YARN-SITE.XML_yarn.nodemanager.aux-services=mapreduce_shuffle
YARN-SITE.XML_yarn.nodemanager.aux-services.mapreduce_shuffle.class=org.apache.hadoop.mapred.ShuffleHandler

MAPRED-SITE.XML_mapreduce.framework.name=yarn
MAPRED-SITE.XML_mapreduce.application.classpath=$HADOOP_HOME/share/hadoop/mapreduce/*:$HADOOP_HOME/share/hadoop/mapreduce/lib/*
